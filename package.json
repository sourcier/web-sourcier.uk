{
  "name": "web-sourcier-uk",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "clean": "rm -rf .astro dist public/pagefind",
    "dev": "pnpm thumbs:copy && SHOW_DRAFTS=true netlify dev",
    "dev:no-drafts": "pnpm thumbs:copy && netlify dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "thumbs:copy": "node scripts/copy-thumbs.mjs",
    "search:index": "pnpm thumbs:copy && astro build && pagefind --site dist && rm -rf public/pagefind && cp -r dist/pagefind public/pagefind"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "astro": "^6.1.1",
    "astro-expressive-code": "^0.41.7",
    "bulma": "^1.0.4",
    "mermaid": "^11.13.0",
    "sass": "^1.98.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@netlify/edge-functions": "^3.0.6",
    "pagefind": "^1.4.0",
    "remark-emoji": "^5.0.2"
  }
}
