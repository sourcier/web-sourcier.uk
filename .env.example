# ── GitHub (private content submodule) ────────────────────────────────────────
# Fine-grained PAT with read-only Contents access to sourcier/web-sourcier.uk-content
# https://github.com/settings/tokens?type=beta
GITHUB_PAT=

# ── Comment approval system ───────────────────────────────────────────────────
# Personal access token — https://app.netlify.com/user/applications
NETLIFY_ACCESS_TOKEN=

# Form ID for the "blog-comments" (pending) form.
# Visible in the Netlify Forms dashboard URL.
COMMENTS_FORM_ID=

# Form ID for the "approved-comments" form.
# Visible in the Netlify Forms dashboard URL after the first comment is approved.
APPROVED_COMMENTS_FORM_ID=

# Random secret for HMAC-signing approve/delete links.
# Generate with: openssl rand -hex 32
APPROVAL_SECRET=

# Public URL of the site, e.g. https://sourcier.uk
SITE_URL=

# ── Resend (email) ────────────────────────────────────────────────────────────
# Resend API key — https://resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=

# Resend segment ID for broadcast emails (Audiences → Segments in the dashboard)
RESEND_SEGMENT_ID=
RESEND_TOPIC_ID=           # Optional — scopes broadcasts to a topic (e.g. "New Posts")

# Published Resend template ID for the welcome email.
# Run: node scripts/create-welcome-template.js to create and publish it.
RESEND_WELCOME_TEMPLATE_ID=

# Verified Resend sender address, e.g. hello@sourcier.uk
NOTIFY_FROM_EMAIL=

# Address to receive comment notification emails
NOTIFY_EMAIL=
