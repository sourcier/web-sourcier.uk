---
interface CreditEntry {
  label: string;
  text: string;
  url?: string;
}

interface Props {
  entries: CreditEntry[];
}

const { entries } = Astro.props;
---

<div class="page-credits">
  <p class="page-credits__heading">Credits</p>
  <ul class="page-credits__list" role="list">
    {
      entries.map((entry) => (
        <li class="page-credits__item">
          <span class="page-credits__label">{entry.label}</span>
          {entry.url ? (
            <a
              class="page-credits__value"
              href={entry.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              {entry.text}
            </a>
          ) : (
            <span class="page-credits__value">{entry.text}</span>
          )}
        </li>
      ))
    }
  </ul>
</div>

<style lang="scss">
  .page-credits {
    min-width: 0;
  }

  .page-credits__heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .page-credits__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .page-credits__item {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-border);
    font-size: 0.75rem;
    line-height: 1.3;
    transition: border-color 0.15s ease;

    &:has(a):hover {
      border-color: var(--color-pink);
      cursor: pointer;
    }
  }

  .page-credits__label {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);

    &::after {
      content: "·";
      margin: 0 0.3rem;
      opacity: 0.4;
    }
  }

  .page-credits__value {
    color: var(--color-muted);
    text-decoration: none;

    .page-credits__item:has(a):hover & {
      color: var(--color-pink);
    }
  }
</style>
