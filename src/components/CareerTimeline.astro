  <style lang="scss">
    .career-timeline__list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .career-section-title {
      font-family: "Barlow Condensed", sans-serif;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      letter-spacing: -0.01em;
      color: var(--color-ink);
      margin-bottom: 3rem;
      padding-left: 1.5rem;

      @media (min-width: 640px) {
        text-align: center;
        padding-left: 0;
      }
    }

    .career-timeline {
      position: relative;
      max-width: 780px;
      margin: 0 auto;
      padding: 0 1.5rem 4rem;

      &::before {
        content: "";
        position: absolute;
        left: calc(1.5rem + 10px);
        top: 0;
        bottom: 0;
        width: 2px;
        background: var(--color-border);

        @media (min-width: 640px) {
          left: 50%;
          transform: translateX(-50%);
        }
      }
    }

    .career-timeline__header {
      text-align: center;
      position: relative;
      margin-bottom: 3rem;

      span {
        display: inline-block;
        background: var(--color-pink);
        color: #ffffff;
        font-family: "Barlow Condensed", sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0.35rem 1rem;
      }
    }

    .career-timeline__item {
      position: relative;
      padding-left: calc(1.5rem + 36px);
      margin-bottom: 2.5rem;

      @media (min-width: 640px) {
        width: 50%;
        padding-left: 0;
        padding-right: 3rem;

        &:nth-child(even) {
          margin-left: 50%;
          padding-right: 0;
          padding-left: 3rem;
        }
      }
    }

    .career-timeline__marker {
      position: absolute;
      left: calc(1.5rem - 1px);
      top: 4px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--color-surface);
      border: 2px solid var(--color-pink);
      z-index: 1;
      transition:
        background-color 0.18s ease,
        box-shadow 0.18s ease;

      .career-timeline__item:hover & {
        background: var(--color-pink);
        box-shadow: 0 0 0 4px rgba(232, 0, 106, 0.2);
      }

      &.is-current {
        background: var(--color-pink);
        box-shadow: 0 0 0 4px rgba(232, 0, 106, 0.2);
      }

      @media (min-width: 640px) {
        left: auto;
        right: -11px;
      }
    }

    .career-timeline__item:nth-child(even) .career-timeline__marker {
      @media (min-width: 640px) {
        right: auto;
        left: -11px;
      }
    }

    .career-timeline__content {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      padding: 1.25rem 1.5rem;
      transition:
        transform 0.18s ease,
        box-shadow 0.18s ease;

      &:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(232, 0, 106, 0.12);
      }
    }

    .career-timeline__period {
      font-family: "Barlow Condensed", sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-pink);
      margin-bottom: 0.4rem;
    }

    .career-timeline__role {
      font-family: "Barlow Condensed", sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.2;
      color: var(--color-ink);
      margin-bottom: 0.2rem;
    }

    .career-timeline__company {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-muted);
      margin-bottom: 0.75rem;
    }

    .career-timeline__description {
      font-size: 0.9rem;
      line-height: 1.7;
      color: var(--color-muted);
    }
  </style>
