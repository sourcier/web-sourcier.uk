---
interface HistoryEntry {
  datetime: Date;
  note: string;
}

interface Props {
  entries: HistoryEntry[];
}

const { entries } = Astro.props;

function formatDatetime(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    timeZone: "Europe/London",
  });
}
---

<div class="page-history">
  <p class="page-history__heading">Page history</p>
  <ol class="page-history__log">
    {
      entries.map((entry) => (
        <li class="page-history__entry">
          <time
            class="page-history__time"
            datetime={entry.datetime.toISOString()}
          >
            {formatDatetime(entry.datetime)}
          </time>
          <span class="page-history__note" set:html={entry.note} />
        </li>
      ))
    }
  </ol>
</div>

<style lang="scss">
  .page-history {
    flex: 2 1 320px;
    min-width: 0;
  }

  .page-history__heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .page-history__log {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1rem;
    border-left: 2px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .page-history__entry {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0;
    position: relative;

    & + & {
      border-top: 1px solid var(--color-border);
    }

    &::before {
      content: "";
      position: absolute;
      left: -1.35rem;
      top: 1rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-border);
      box-shadow: 0 0 0 2px var(--color-surface);
    }
  }

  .page-history__time {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    opacity: 0.7;
  }

  .page-history__note {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
