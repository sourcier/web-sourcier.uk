---
import newdayLogo from "../../assets/images/newday-favicon.png";
import intofilmLogo from "../../assets/images/intofilm-favicon.png";
import treatwellLogo from "../../assets/images/treatwell-favicon.png";
import { faLinkedin } from "@fortawesome/free-brands-svg-icons";
import { faIcon } from "../utils/icons";

const linkedinIcon = faIcon(faLinkedin, { size: 14 });

const testimonials = [
  {
    quote:
      "As a product designer I've enjoyed working with Roger on New Day's SaaS product Fusion. He's a collaborative engineering lead who is deeply engaged in problem solving and thinks outside the box to find the best solutions for both business and users. Easy to approach, calm and always happy to talk through ideas, Roger is a great colleague to work with.",
    name: "Elise Ten Cate",
    title: "Product Designer",
    company: "NewDay",
    logo: newdayLogo,
    website: "https://www.newday.co.uk",
    linkedin: "https://www.linkedin.com/in/elisabethtencate/",
    placeholder: false,
  },
  {
    quote:
      "When we hired Roger a decade ago at Into Film, we couldn't decide between him and another candidate—so naturally, we took them both. Turns out Roger was worth it. As a principal software engineer, he solves problems I didn't even know existed, with a calm that makes the chaos of charity work look orderly. Ten years later, I still think hiring him was the smarter half of that indecision.",
    name: "Chris Breen",
    title: "Lead Engineer",
    company: "Into Film",
    logo: intofilmLogo,
    website: "https://www.intofilm.org",
    linkedin: "https://www.linkedin.com/in/chris-breen-b608aa42/",
    placeholder: false,
  },
  {
    quote:
      "Roger is, without question, one of the best technologists I know—a genuine visionary who translates innovative ideas into real-world impact and helps define best practices. His leadership is calm, thoughtful, and earns respect at every level. What sets him apart most is his gift as a teacher and mentor; throughout my career he has been my go-to for complex technical challenges and important career decisions alike.",
    name: "Syed Shah",
    title: "Senior Security Engineer",
    company: "Treatwell",
    logo: treatwellLogo,
    website: "https://www.treatwell.co.uk",
    linkedin: "https://www.linkedin.com/in/syed-shah-6a881917/",
    placeholder: false,
  },
];
---

<section class="testimonials" aria-labelledby="testimonials-heading">
  <div class="container is-max-desktop">
    <p class="section-label" id="testimonials-heading">What people say</p>
    <ul class="testimonials__list" role="list">
      {
        testimonials.map((t) =>
          t.placeholder ? (
            <li
              class="testimonials__item testimonials__item--placeholder"
              aria-hidden="true"
            >
              <div class="testimonials__placeholder-inner">
                <span class="testimonials__placeholder-label">
                  More testimonials coming soon
                </span>
              </div>
            </li>
          ) : (
            <li class="testimonials__item">
              <blockquote class="testimonials__quote">
                <p>&ldquo;{t.quote}&rdquo;</p>
              </blockquote>
              <footer class="testimonials__footer">
                <div class="testimonials__attribution">
                  <div>
                    <p class="testimonials__name">
                      {t.linkedin ? (
                        <span class="testimonials__name-group">
                          <a
                            href={t.linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="testimonials__name-link"
                          >
                            {t.name}
                          </a>
                          <a
                            href={t.linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="testimonials__linkedin"
                            aria-label={`${t.name} on LinkedIn`}
                            set:html={linkedinIcon}
                          />
                        </span>
                      ) : (
                        t.name
                      )}
                    </p>
                    <p class="testimonials__meta">
                      {t.title ? `${t.title} · ${t.company}` : t.company}
                    </p>
                  </div>
                  {t.logo && (
                    <a
                      href={t.website}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="testimonials__logo-link"
                      aria-label={`Visit ${t.company} website`}
                    >
                      <img
                        src={t.logo.src}
                        alt={t.company}
                        class="testimonials__logo"
                        width="64"
                        height="64"
                        loading="lazy"
                      />
                    </a>
                  )}
                </div>
              </footer>
            </li>
          ),
        )
      }
    </ul>
  </div>
</section>

<style lang="scss">
  .testimonials {
    padding: 4rem 1.5rem;
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .testimonials__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @media (min-width: 768px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .testimonials__item {
    display: flex;
    flex-direction: column;
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-pink);
    background-color: var(--color-paper);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;

    &:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(232, 0, 106, 0.12);
    }
  }

  .testimonials__quote {
    flex: 1;
    margin: 0 0 1.5rem;

    p {
      font-size: 0.9375rem;
      line-height: 1.8;
      color: var(--color-ink);
      margin: 0;
      font-style: italic;
    }
  }

  .testimonials__footer {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }

  .testimonials__attribution {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .testimonials__logo-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .testimonials__logo {
    flex-shrink: 0;
    max-width: 64px;
    max-height: 32px;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.65;
    filter: grayscale(1);
    transition:
      opacity 0.18s ease,
      filter 0.18s ease;

    html[data-theme="dark"] & {
      filter: grayscale(1) invert(1);
    }
  }

  .testimonials__item:hover .testimonials__logo {
    opacity: 1;
    filter: grayscale(0);

    html[data-theme="dark"] & {
      filter: grayscale(0) invert(0);
    }
  }

  .testimonials__item--placeholder {
    cursor: default;
    border: 2px dashed var(--color-border);
    border-top: 2px dashed var(--color-border);
    background: transparent;
    box-shadow: none;

    &:hover {
      transform: none;
      box-shadow: none;
    }
  }

  .testimonials__placeholder-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 2rem 1rem;
  }

  .testimonials__placeholder-label {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-border);
  }

  .testimonials__name {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    margin: 0 0 0.2rem;
  }

  .testimonials__name-group {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;

    &:hover .testimonials__name-link {
      color: var(--color-pink);
    }

    &:hover .testimonials__linkedin {
      color: var(--color-pink);
    }
  }

  .testimonials__name-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .testimonials__linkedin {
    display: inline-flex;
    align-items: center;
    color: var(--color-muted);
    transition: color 0.15s ease;
    flex-shrink: 0;
  }

  .testimonials__meta {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin: 0;
  }
</style>
