---
import newdayLogo from "../../assets/images/newday-favicon.png";
import intofilmLogo from "../../assets/images/intofilm-favicon.png";
import treatwellLogo from "../../assets/images/treatwell-favicon.png";
import { faLinkedin } from "@fortawesome/free-brands-svg-icons";
import { faPause, faPlay } from "@fortawesome/free-solid-svg-icons";
import { faIcon } from "../utils/icons";

const linkedinIcon = faIcon(faLinkedin, { size: 14 });
const pauseIcon = faIcon(faPause, { size: 11 });
const playIcon = faIcon(faPlay, { size: 11 });

const testimonials = [
  {
    quote:
      "As a product designer I've enjoyed working with Roger on New Day's SaaS product Fusion. He's a collaborative engineering lead who is deeply engaged in problem solving and thinks outside the box to find the best solutions for both business and users. Easy to approach, calm and always happy to talk through ideas, Roger is a great colleague to work with.",
    name: "Elise Ten Cate",
    title: "Product Designer",
    company: "NewDay",
    logo: newdayLogo,
    website: "https://www.newday.co.uk",
    linkedin: "https://www.linkedin.com/in/elisabethtencate/",
  },
  {
    quote:
      "Roger has been an exceptional tech lead and manager during my time at NewDay. He has a real ability to quickly unblock problems and create an environment where engineers can do their best work. He has been a great mentor to me and played a significant role in helping me progress from a mid-level to a senior engineer. I've learned a huge amount from working with him and really value the experience of having worked together.",
    name: "Gladwin Dosunmu",
    title: "Senior Engineer",
    company: "NewDay",
    logo: newdayLogo,
    website: "https://www.newday.co.uk",
    linkedin: "https://www.linkedin.com/in/gladwin-dosunmu-80691b107/",
  },
  {
    quote:
      "Roger is, without question, one of the best technologists I know—a genuine visionary who translates innovative ideas into real-world impact and helps define best practices. His leadership is calm, thoughtful, and earns respect at every level. What sets him apart most is his gift as a teacher and mentor; throughout my career he has been my go-to for complex technical challenges and important career decisions alike.",
    name: "Syed Shah",
    title: "Senior Security Engineer",
    company: "Treatwell",
    logo: treatwellLogo,
    website: "https://www.treatwell.co.uk",
    linkedin: "https://www.linkedin.com/in/syed-shah-6a881917/",
  },
  {
    quote:
      "When we hired Roger a decade ago at Into Film, we couldn't decide between him and another candidate—so naturally, we took them both. Turns out Roger was worth it. As a principal software engineer, he solves problems I didn't even know existed, with a calm that makes the chaos of charity work look orderly. Ten years later, I still think hiring him was the smarter half of that indecision.",
    name: "Chris Breen",
    title: "Lead Engineer",
    company: "Into Film",
    logo: intofilmLogo,
    website: "https://www.intofilm.org",
    linkedin: "https://www.linkedin.com/in/chris-breen-b608aa42/",
  },
];
---

<section class="testimonials" aria-labelledby="testimonials-heading">
  <div class="container is-max-desktop">
    <div class="testimonials__header">
      <p class="section-label" id="testimonials-heading">
        From people I've worked with
      </p>
      <button
        class="testimonials__pause-btn"
        type="button"
        aria-label="Pause slideshow"
        aria-pressed="false"
      >
        <span class="testimonials__pause-icon" set:html={pauseIcon} />
        <span class="testimonials__play-icon" set:html={playIcon} />
      </button>
    </div>

    <div
      class="testimonials__carousel"
      role="region"
      aria-roledescription="carousel"
      aria-label="Testimonials"
    >
      <div class="testimonials__track-wrapper">
        <ul class="testimonials__track" role="list">
          {
            testimonials.map((t, i) => (
              <li
                class="testimonials__item"
                role="group"
                aria-roledescription="slide"
                aria-label={`${i + 1} of ${testimonials.length}`}
              >
                <blockquote class="testimonials__quote">
                  <p>&ldquo;{t.quote}&rdquo;</p>
                </blockquote>
                <footer class="testimonials__footer">
                  <div class="testimonials__attribution">
                    <div>
                      <p class="testimonials__name">
                        <span class="testimonials__name-group">
                          <a
                            href={t.linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="testimonials__name-link"
                          >
                            {t.name}
                          </a>
                          <a
                            href={t.linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="testimonials__linkedin"
                            aria-label={`${t.name} on LinkedIn`}
                            set:html={linkedinIcon}
                          />
                        </span>
                      </p>
                      <p class="testimonials__meta">
                        {t.title ? `${t.title} · ${t.company}` : t.company}
                      </p>
                    </div>
                    {t.logo && (
                      <a
                        href={t.website}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="testimonials__logo-link"
                        aria-label={`Visit ${t.company} website`}
                      >
                        <img
                          src={t.logo.src}
                          alt={t.company}
                          class="testimonials__logo"
                          width="64"
                          height="64"
                          loading="lazy"
                        />
                      </a>
                    )}
                  </div>
                </footer>
              </li>
            ))
          }
        </ul>
      </div>

      <div
        class="testimonials__dots"
        role="group"
        aria-label="Slide navigation"
      >
        {
          testimonials.map((t, i) => (
            <button
              class:list={["testimonials__dot", { "is-active": i === 0 }]}
              type="button"
              aria-label={`Go to slide ${i + 1}: ${t.name}`}
              aria-current={i === 0 ? "true" : "false"}
              data-index={i}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector<HTMLElement>(".testimonials");
  if (section) {
    const track = section.querySelector<HTMLElement>(".testimonials__track")!;
    const dots =
      section.querySelectorAll<HTMLButtonElement>(".testimonials__dot");
    const pauseBtn = section.querySelector<HTMLButtonElement>(
      ".testimonials__pause-btn",
    )!;
    const carousel = section.querySelector<HTMLElement>(
      ".testimonials__carousel",
    )!;
    const total = dots.length;
    let current = 0;
    let paused = false;
    let timer: ReturnType<typeof setInterval> | null = null;

    function getLayout() {
      const wrapper = track.parentElement as HTMLElement;
      const items = track.querySelectorAll<HTMLElement>(".testimonials__item");
      const wrapperWidth = wrapper.getBoundingClientRect().width;
      const itemWidth = items[0]?.getBoundingClientRect().width ?? wrapperWidth;
      let stepPct = 100;
      if (items.length > 1) {
        const r0 = items[0].getBoundingClientRect();
        const r1 = items[1].getBoundingClientRect();
        stepPct = ((r1.left - r0.left) / wrapperWidth) * 100;
      }
      const visible = Math.round(wrapperWidth / itemWidth);
      const maxIndex = Math.max(0, total - visible);
      return { stepPct, maxIndex };
    }

    function goTo(index: number) {
      const { stepPct, maxIndex } = getLayout();
      current = ((index % (maxIndex + 1)) + (maxIndex + 1)) % (maxIndex + 1);
      track.style.transform = `translateX(-${current * stepPct}%)`;
      dots.forEach((d, i) => {
        const hidden = i > maxIndex;
        d.classList.toggle("is-active", i === current);
        d.classList.toggle("is-hidden", hidden);
        d.setAttribute("aria-current", i === current ? "true" : "false");
      });
    }

    function startTimer() {
      if (timer) clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    function stopTimer() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        goTo(parseInt(dot.dataset.index!, 10));
        stopTimer();
        if (!paused) startTimer();
      });
    });

    pauseBtn.addEventListener("click", () => {
      paused = !paused;
      pauseBtn.setAttribute("aria-pressed", String(paused));
      pauseBtn.setAttribute(
        "aria-label",
        paused ? "Play slideshow" : "Pause slideshow",
      );
      pauseBtn.classList.toggle("is-paused", paused);
      if (paused) stopTimer();
      else startTimer();
    });

    carousel.addEventListener("mouseenter", stopTimer);
    carousel.addEventListener("mouseleave", () => {
      if (!paused) startTimer();
    });
    carousel.addEventListener("focusin", stopTimer);
    carousel.addEventListener("focusout", (e) => {
      if (
        !carousel.contains((e as FocusEvent).relatedTarget as Node) &&
        !paused
      ) {
        startTimer();
      }
    });

    carousel.addEventListener("keydown", (e) => {
      const key = (e as KeyboardEvent).key;
      if (key === "ArrowLeft" || key === "ArrowRight") {
        goTo(key === "ArrowLeft" ? current - 1 : current + 1);
        stopTimer();
        if (!paused) startTimer();
      }
    });

    new ResizeObserver(() => goTo(current)).observe(track.parentElement!);

    goTo(0);

    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      startTimer();
    }
  }
</script>

<style lang="scss">
  .testimonials {
    padding: 4rem 1.5rem;
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .testimonials__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;

    .section-label {
      margin-bottom: 0;
    }
  }

  .testimonials__pause-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;

    .testimonials__play-icon {
      display: none;
    }

    &.is-paused {
      .testimonials__pause-icon {
        display: none;
      }
      .testimonials__play-icon {
        display: flex;
      }
    }

    &:hover {
      color: var(--color-pink);
      border-color: rgba(232, 0, 106, 0.5);
    }
  }

  .testimonials__carousel {
    position: relative;
  }

  .testimonials__track-wrapper {
    overflow: hidden;
  }

  .testimonials__track {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;

    @media (prefers-reduced-motion: reduce) {
      transition: none;
    }
  }

  .testimonials__item {
    flex: 0 0 100%;
    min-width: 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-pink);
    background-color: var(--color-paper);

    @media (min-width: 640px) {
      flex: 0 0 calc(50% - 0.625rem);
    }
  }

  .testimonials__quote {
    flex: 1;
    margin: 0 0 1.5rem;

    p {
      font-size: 0.9375rem;
      line-height: 1.8;
      color: var(--color-ink);
      margin: 0;
      font-style: italic;
    }
  }

  .testimonials__footer {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }

  .testimonials__attribution {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .testimonials__logo-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .testimonials__logo {
    flex-shrink: 0;
    max-width: 64px;
    max-height: 32px;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.65;
    filter: grayscale(1);
    transition:
      opacity 0.18s ease,
      filter 0.18s ease;

    html[data-theme="dark"] & {
      filter: grayscale(1) invert(1);
    }
  }

  .testimonials__item:hover .testimonials__logo {
    opacity: 1;
    filter: grayscale(0);

    html[data-theme="dark"] & {
      filter: grayscale(0) invert(0);
    }
  }

  .testimonials__name {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    margin: 0 0 0.2rem;
  }

  .testimonials__name-group {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;

    &:hover .testimonials__name-link {
      color: var(--color-pink);
    }

    &:hover .testimonials__linkedin {
      color: var(--color-pink);
    }
  }

  .testimonials__name-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .testimonials__linkedin {
    display: inline-flex;
    align-items: center;
    color: var(--color-muted);
    transition: color 0.15s ease;
    flex-shrink: 0;
  }

  .testimonials__meta {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin: 0;
  }

  .testimonials__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding-top: 1.5rem;
  }

  .testimonials__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease;

    &.is-active {
      background: var(--color-pink);
      transform: scale(1.375);
    }

    &:hover:not(.is-active) {
      background: var(--color-muted);
    }

    &.is-hidden {
      display: none;
    }
  }
</style>
