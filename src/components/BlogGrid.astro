---
import BlogPost from "./BlogPost.astro";

interface Props {
  posts: any[];
  currentPage: number;
  totalPages: number;
  prevUrl: string | null;
  nextUrl: string | null;
}

const { posts, currentPage, totalPages, prevUrl, nextUrl } = Astro.props;

const COLS = 3;
const placeholderCount =
  currentPage === totalPages ? (COLS - (posts.length % COLS)) % COLS : 0;

function pageUrl(n: number) {
  return n === 1 ? "/blog" : `/blog/page/${n}`;
}
---

<section class="section">
  <div class="container is-max-desktop">
    <div
      class="fixed-grid has-1-cols-mobile has-3-cols-tablet has-3-cols-desktop"
    >
      <div class="grid">
        {
          posts.map((post: any) => (
            <div class="cell">
              <BlogPost
                title={post.data.title}
                subTitle={post.data.subTitle}
                description={post.data.description}
                url={`/blog/${post.id}`}
                cover={post.data.cover}
                pubDate={post.data.pubDate}
                draft={post.data.draft}
              />
            </div>
          ))
        }
        {
          Array.from({ length: placeholderCount }).map(() => (
            <div class="cell">
              <div
                class="card card__blog card__blog--placeholder"
                aria-hidden="true"
              >
                <div class="card__blog--placeholder-inner">
                  <span class="card__blog--placeholder-label">
                    More posts coming soon
                  </span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {
      totalPages > 1 && (
        <nav class="pagination-nav" aria-label="Blog pagination">
          <a
            href={prevUrl}
            class={`pagination-nav__btn${!prevUrl ? " pagination-nav__btn--disabled" : ""}`}
            aria-disabled={!prevUrl}
            tabindex={!prevUrl ? -1 : 0}
          >
            &larr; Previous
          </a>

          <div class="pagination-nav__pages" role="list">
            {Array.from({ length: totalPages }).map((_, i) => {
              const n = i + 1;
              return (
                <a
                  href={pageUrl(n)}
                  role="listitem"
                  class={`pagination-nav__page${n === currentPage ? " pagination-nav__page--active" : ""}`}
                  aria-current={n === currentPage ? "page" : undefined}
                >
                  {n}
                </a>
              );
            })}
          </div>

          <a
            href={nextUrl}
            class={`pagination-nav__btn${!nextUrl ? " pagination-nav__btn--disabled" : ""}`}
            aria-disabled={!nextUrl}
            tabindex={!nextUrl ? -1 : 0}
          >
            Next &rarr;
          </a>
        </nav>
      )
    }
  </div>
</section>

<style lang="scss">
  /* ── Pagination ───────────────────────────────────────────── */
  .pagination-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .pagination-nav__pages {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .pagination-nav__page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 4px;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-ink);
    text-decoration: none;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;

    &:hover {
      background-color: var(--color-surface);
    }

    &--active {
      background-color: var(--color-pink);
      color: #fff;

      &:hover {
        background-color: var(--color-pink);
      }
    }
  }

  .pagination-nav__btn {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.15s ease;

    &:hover {
      color: var(--color-pink);
    }

    &--disabled {
      color: var(--color-muted);
      pointer-events: none;
    }
  }

  /* ── Placeholder card ────────────────────────────────────── */
  .card__blog--placeholder {
    pointer-events: none;
    border: 2px dashed var(--color-border);
    border-top: 2px dashed var(--color-border);
    background: transparent;
    box-shadow: none;

    &-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1;
      padding: 2rem 1.5rem;
    }

    &-label {
      font-family: "Barlow Condensed", sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-border);
    }
  }
</style>
