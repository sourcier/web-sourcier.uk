<footer class="footer mt-auto">
  <div class="footer__inner">
    <div class="footer__tagline">
      <span class="footer__word">Make things</span>
      <span class="footer__divider">/</span>
      <span class="footer__word">Break things</span>
      <span class="footer__divider">/</span>
      <span class="footer__word">Fix things</span>
      <span class="footer__divider">/</span>
      <span class="footer__word"
        >Repeat <span class="footer__arrow" aria-hidden="true">&#x21BA;</span
        ></span
      >
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">&copy; 2026 Roger Rajaratnam</p>
      <div class="footer__social">
        <a
          href="https://github.com/sourcier"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="GitHub"
        >
          <svg
            aria-hidden="true"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            ><path
              d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.461-1.11-1.461-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.03-2.682-.103-.253-.447-1.27.098-2.646 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.547 1.376.203 2.394.1 2.646.641.698 1.028 1.591 1.028 2.682 0 3.841-2.337 4.687-4.565 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.417 22 12c0-5.523-4.477-10-10-10z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.linkedin.com/in/roger-rajaratnam"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="LinkedIn"
        >
          <svg
            aria-hidden="true"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            ><path
              d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zm-1 16v-5.5c0-1.378-.498-2.333-1.742-2.333-.951 0-1.516.639-1.766 1.257-.091.221-.114.529-.114.839V19H12V10h2.352v1.177h.032c.327-.619 1.124-1.511 2.614-1.511 1.913 0 3.002 1.257 3.002 3.55V19H18zm-9.5-9.727a1.386 1.386 0 1 1 0-2.773 1.386 1.386 0 0 1 0 2.773zM7.25 19H9.5V10H7.25v9z"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</footer>

<style lang="scss">
  .footer {
    background-color: #0f0f0f;
    color: rgba(255, 255, 255, 0.5);
    padding: 3rem 1.5rem 2rem;
    border-top: 3px solid var(--color-pink);
  }

  .footer__inner {
    max-width: 75rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer__tagline {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.15);
    line-height: 1;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.4em;
  }

  // Total cycle: 4 words × 1s on + 3s off = 16s loop
  @keyframes word-highlight {
    0%,
    100% {
      color: rgba(255, 255, 255, 0.15);
    }
    5% {
      color: rgba(255, 255, 255, 0.45);
    }
    20% {
      color: rgba(255, 255, 255, 0.15);
    }
  }

  .footer__word {
    color: rgba(255, 255, 255, 0.15);
    animation: word-highlight 16s ease-in-out infinite;

    &:nth-child(1) {
      animation-delay: 0s;
    }
    &:nth-child(3) {
      animation-delay: 4s;
    }
    &:nth-child(5) {
      animation-delay: 8s;
    }
    &:nth-child(7) {
      animation-delay: 12s;
    }
  }

  @keyframes arrow-opacity {
    0%,
    100% {
      opacity: 0.25;
    }
    5% {
      opacity: 1;
    }
    20% {
      opacity: 0.25;
    }
  }

  .footer__arrow {
    color: var(--color-pink);
    opacity: 0.25;
    animation: arrow-opacity 16s ease-in-out infinite;
    animation-delay: 12s;
  }

  .footer__divider {
    color: var(--color-pink);
    opacity: 0.4;
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__copy {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }

  .footer__social {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  // Override global social icon colours for the dark footer
  .social-icon {
    color: rgba(255, 255, 255, 0.4);

    &:hover {
      color: var(--color-pink);
    }
  }
</style>
