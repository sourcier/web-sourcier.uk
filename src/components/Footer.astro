---
import { faDesktop, faSun, faMoon } from "@fortawesome/free-solid-svg-icons";
import { faIcon } from "../utils/icons";

const systemIcon = faIcon(faDesktop, { size: 14 });
const sunIcon = faIcon(faSun, { size: 14 });
const moonIcon = faIcon(faMoon, { size: 14 });
---

<footer class="footer mt-auto">
  <div class="footer__inner">
    <div class="footer__tagline">
      <span class="footer__word">Make things</span>
      <span class="footer__divider">/</span>
      <span class="footer__word">Break things</span>
      <span class="footer__divider">/</span>
      <span class="footer__word">Fix things</span>
      <span class="footer__divider">/</span>
      <span class="footer__word"
        >Repeat <span class="footer__arrow" aria-hidden="true">&#x21BA;</span
        ></span
      >
    </div>

    <div class="footer__bottom">
      <div class="theme-toggle" role="group" aria-label="Theme preference">
        <button
          class="theme-toggle__btn"
          data-theme-select="system"
          aria-label="System theme"
          aria-pressed="true"
        >
          <Fragment set:html={systemIcon} />
          <span class="theme-toggle__label">System</span>
        </button>
        <button
          class="theme-toggle__btn"
          data-theme-select="light"
          aria-label="Light theme"
          aria-pressed="false"
        >
          <Fragment set:html={sunIcon} />
          <span class="theme-toggle__label">Light</span>
        </button>
        <button
          class="theme-toggle__btn"
          data-theme-select="dark"
          aria-label="Dark theme"
          aria-pressed="false"
        >
          <Fragment set:html={moonIcon} />
          <span class="theme-toggle__label">Dark</span>
        </button>
      </div>
      <p class="footer__copy">&copy; 2026 Roger Rajaratnam</p>
    </div>
  </div>
</footer>

<style lang="scss">
  .footer {
    background-color: #0f0f0f;
    color: rgba(255, 255, 255, 0.5);
    padding: 3rem 1.5rem 2rem;
    border-top: 3px solid var(--color-pink);
  }

  .footer__inner {
    max-width: 75rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer__tagline {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.15);
    line-height: 1;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.4em;
  }

  .footer__word {
    color: rgba(255, 255, 255, 0.15);
  }

  .footer__arrow {
    color: var(--color-pink);
    opacity: 0.25;
  }

  // Total cycle: 4 words × 1s on + 3s off = 16s loop
  @media (prefers-reduced-motion: no-preference) {
    @keyframes word-highlight {
      0%,
      100% {
        color: rgba(255, 255, 255, 0.15);
      }
      5% {
        color: rgba(255, 255, 255, 0.45);
      }
      20% {
        color: rgba(255, 255, 255, 0.15);
      }
    }

    .footer__word {
      animation: word-highlight 16s ease-in-out infinite;

      &:nth-child(1) {
        animation-delay: 0s;
      }
      &:nth-child(3) {
        animation-delay: 4s;
      }
      &:nth-child(5) {
        animation-delay: 8s;
      }
      &:nth-child(7) {
        animation-delay: 12s;
      }
    }

    @keyframes arrow-opacity {
      0%,
      100% {
        opacity: 0.25;
      }
      5% {
        opacity: 1;
      }
      20% {
        opacity: 0.25;
      }
    }

    .footer__arrow {
      animation: arrow-opacity 16s ease-in-out infinite;
      animation-delay: 12s;
    }
  }

  .footer__divider {
    color: var(--color-pink);
    opacity: 0.4;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    padding: 2px;
    gap: 2px;
  }

  .theme-toggle__btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: rgba(255, 255, 255, 0.4);
    font-family: "Barlow", sans-serif;
    font-size: 0.75rem;
    cursor: pointer;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;

    &[aria-pressed="true"] {
      background: rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.9);
    }

    &:hover:not([aria-pressed="true"]) {
      color: rgba(255, 255, 255, 0.65);
    }

    :global(svg) {
      width: 0.75rem;
      height: 0.75rem;
    }
  }

  .footer__copy {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    "[data-theme-select]",
  );
  const html = document.documentElement;

  function setTheme(mode: string) {
    buttons.forEach((btn) =>
      btn.setAttribute(
        "aria-pressed",
        btn.dataset.themeSelect === mode ? "true" : "false",
      ),
    );
    if (mode === "system") {
      localStorage.removeItem("theme");
      html.setAttribute(
        "data-theme",
        window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light",
      );
    } else {
      localStorage.setItem("theme", mode);
      html.setAttribute("data-theme", mode);
    }
  }

  const stored = localStorage.getItem("theme");
  setTheme(stored === "dark" || stored === "light" ? stored : "system");

  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", (e) => {
      if (!localStorage.getItem("theme")) {
        html.setAttribute("data-theme", e.matches ? "dark" : "light");
      }
    });

  buttons.forEach((btn) =>
    btn.addEventListener("click", () => setTheme(btn.dataset.themeSelect!)),
  );
</script>
