---
import avatarImage from "../../assets/images/avatar.jpeg";
import { faGithub, faLinkedin } from "@fortawesome/free-brands-svg-icons";
import {
  faMagnifyingGlass,
  faMoon,
  faSun,
} from "@fortawesome/free-solid-svg-icons";
import { faIcon } from "../utils/icons";

const githubIcon = faIcon(faGithub, { size: 18 });
const linkedinIcon = faIcon(faLinkedin, { size: 18 });
const moonIcon = faIcon(faMoon, { size: 18 });
const sunIcon = faIcon(faSun, { size: 18 });
const searchIcon = faIcon(faMagnifyingGlass, { size: 18 });
---

<nav class="navbar" role="navigation" aria-label="main navigation">
  <div class="container">
    <div class="navbar-brand">
      <a class="navbar-item" href="/">
        <figure class="image">
          <img
            src={avatarImage.src}
            alt="Roger Rajaratnam avatar"
            class="is-rounded"
          />
        </figure>
        <span class="navbar-brand-name">Sourcier</span>
      </a>

      <button
        class="navbar-burger"
        aria-label="menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
        data-target="mobileMenu"
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>

    <div id="mobileMenu" class="navbar-menu">
      <div class="navbar-start">
        <a class="navbar-item" href="/about">About</a>
        <a class="navbar-item" href="/blog">Blog</a>
        <a class="navbar-item" href="/contact">Contact</a>
      </div>

      <div class="navbar-end">
        <div class="navbar-item">
          <div class="buttons">
            <button
              class="social-icon"
              aria-label="Open search"
              data-search-open
            >
              <Fragment set:html={searchIcon} />
            </button>
            <a
              href="https://github.com/sourcier"
              target="_blank"
              rel="noopener noreferrer"
              class="social-icon"
              aria-label="GitHub"
            >
              <Fragment set:html={githubIcon} />
            </a>
            <a
              href="https://www.linkedin.com/in/roger-rajaratnam"
              target="_blank"
              rel="noopener noreferrer"
              class="social-icon"
              aria-label="LinkedIn"
            >
              <Fragment set:html={linkedinIcon} />
            </a>
            <button
              class="social-icon"
              data-theme-toggle
              aria-label="Change to dark theme"
            >
              <span class="moonIcon" set:html={moonIcon} />
              <span class="sunIcon" set:html={sunIcon} />
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<div
  id="search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Site search"
  hidden
>
  <div class="search-backdrop" data-search-close></div>
  <div class="search-panel">
    <div class="search-input-wrap">
      <span class="search-input-icon" aria-hidden="true">
        <Fragment set:html={searchIcon} />
      </span>
      <input
        id="search-input"
        type="search"
        placeholder="Search posts…"
        autocomplete="off"
        spellcheck="false"
        aria-autocomplete="list"
        aria-controls="search-results"
        aria-label="Search query"
      />
      <button class="search-close" aria-label="Close search" data-search-close
        >✕</button
      >
    </div>
    <ul id="search-results" role="listbox" aria-label="Search results"></ul>
  </div>
</div>

<script is:inline>
  (function () {
    const modal = document.getElementById("search-modal");
    const input = document.getElementById("search-input");
    const resultsList = document.getElementById("search-results");
    const openBtns = document.querySelectorAll("[data-search-open]");
    const closeTriggers = document.querySelectorAll("[data-search-close]");

    let pagefind = null;
    let activeIndex = -1;

    async function initPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import("/pagefind/pagefind.js");
        await pagefind.init();
      } catch {
        pagefind = null;
      }
      return pagefind;
    }

    function openModal() {
      modal.removeAttribute("hidden");
      document.body.style.overflow = "hidden";
      input.focus();
    }

    function closeModal() {
      modal.setAttribute("hidden", "");
      document.body.style.overflow = "";
      input.value = "";
      resultsList.innerHTML = "";
      activeIndex = -1;
    }

    function renderResults(results) {
      activeIndex = -1;
      if (!results.length) {
        resultsList.innerHTML =
          '<li class="search-no-results">No results found.</li>';
        return;
      }
      resultsList.innerHTML = results
        .map(
          (r, i) =>
            `<li role="option" aria-selected="false" class="search-result" data-index="${i}">
          <a href="${r.url}" class="search-result__link" tabindex="-1">
            ${r.meta?.image ? `<img src="${r.meta.image}" alt="" class="search-result__thumb" aria-hidden="true" />` : '<div class="search-result__thumb search-result__thumb--placeholder"></div>'}
            <div class="search-result__body">
              <span class="search-result__title">${r.meta?.title ?? "Untitled"}</span>
              ${r.excerpt ? `<span class="search-result__excerpt">${r.excerpt}</span>` : ""}
            </div>
          </a>
        </li>`,
        )
        .join("");

      resultsList.querySelectorAll(".search-result__link").forEach((link) => {
        link.addEventListener("click", closeModal);
      });
    }

    function setActive(index) {
      const items = resultsList.querySelectorAll(".search-result");
      items.forEach((el, i) => {
        const active = i === index;
        el.setAttribute("aria-selected", String(active));
        el.classList.toggle("is-active", active);
      });
      activeIndex = index;
    }

    async function handleInput() {
      const query = input.value.trim();
      if (!query) {
        resultsList.innerHTML = "";
        return;
      }
      const pf = await initPagefind();
      if (!pf) {
        resultsList.innerHTML =
          '<li class="search-no-results">Search unavailable.</li>';
        return;
      }
      const search = await pf.search(query);
      const data = await Promise.all(
        search.results.slice(0, 6).map((r) => r.data()),
      );
      renderResults(data);
    }

    input.addEventListener("input", handleInput);

    input.addEventListener("keydown", (e) => {
      const items = resultsList.querySelectorAll(".search-result");
      if (!items.length) return;
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(Math.min(activeIndex + 1, items.length - 1));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(Math.max(activeIndex - 1, 0));
      } else if (e.key === "Enter" && activeIndex >= 0) {
        e.preventDefault();
        items[activeIndex].querySelector("a")?.click();
      }
    });

    openBtns.forEach((btn) => btn.addEventListener("click", openModal));
    closeTriggers.forEach((el) => el.addEventListener("click", closeModal));

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.hasAttribute("hidden")) closeModal();
    });
  })();
</script>

<script>
  const button = document.querySelector("[data-theme-toggle]");
  const htmlElement = document.documentElement;

  const handleThemeToggle = () => {
    const isDark = htmlElement.getAttribute("data-theme") === "dark";
    const newTheme = isDark ? "light" : "dark";
    const newCta =
      newTheme === "dark" ? "Change to light theme" : "Change to dark theme";

    button?.setAttribute("aria-label", newCta);
    htmlElement.setAttribute("data-theme", newTheme);
    localStorage.setItem("theme", newTheme);
  };

  const theme = (() => {
    const localStorageTheme = localStorage?.getItem("theme") ?? "";
    if (["dark", "light"].includes(localStorageTheme)) {
      return localStorageTheme;
    }

    return "light";
  })();

  if (theme === "light") {
    htmlElement.setAttribute("data-theme", "light");
    button?.setAttribute("aria-label", "Change to dark theme");
  } else {
    htmlElement.setAttribute("data-theme", "dark");
    button?.setAttribute("aria-label", "Change to light theme");
  }

  button?.addEventListener("click", handleThemeToggle);
</script>

<style lang="scss">
  html[data-theme="light"] {
    .moonIcon {
      display: flex;
      align-items: center;
    }
    .sunIcon {
      display: none;
    }
  }
  html[data-theme="dark"] {
    .moonIcon {
      display: none;
    }
    .sunIcon {
      display: flex;
      align-items: center;
    }
  }
</style>
