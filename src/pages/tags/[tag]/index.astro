---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import BlogGrid from "../../../components/BlogGrid.astro";
import MailingListCTA from "../../../components/MailingListCTA.astro";
import { tagSlug } from "../../../utils/tags";

const PAGE_SIZE = 9;

export async function getStaticPaths() {
  const allPosts = (await getCollection("posts")).filter(
    (post) => !post.data.draft || import.meta.env.DEV,
  );

  const tagMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const slug = tagSlug(tag);
      if (!tagMap.has(slug)) tagMap.set(slug, []);
      tagMap.get(slug)!.push(post);
    }
  }

  return [...tagMap.entries()].map(([slug, posts]) => {
    const sorted = posts.sort(
      (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
    );
    const totalPages = Math.ceil(sorted.length / 9);
    const label = posts[0].data.tags.find((t) => tagSlug(t) === slug) ?? slug;
    return {
      params: { tag: slug },
      props: {
        label,
        posts: sorted.slice(0, 9),
        totalPages,
        nextUrl: totalPages > 1 ? `/tags/${slug}/2` : null,
      },
    };
  });
}

const { label, posts, totalPages, nextUrl } = Astro.props;
const { tag } = Astro.params;
---

<BaseLayout
  pageTitle={`${label} — Tags — Sourcier`}
  description={`Blog posts tagged with "${label}" on Sourcier.`}
>
  <PageHero
    kicker="Tag"
    title={label}
    subtitle={`All posts tagged with "${label}".`}
    crumbs={[
      { label: "Blog", href: "/blog" },
      { label: "Tags", href: "/tags" },
      { label },
    ]}
  />

  <BlogGrid
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
    prevUrl={null}
    nextUrl={nextUrl}
    paginationBase={`/tags/${tag}`}
  />

  <MailingListCTA />
</BaseLayout>
