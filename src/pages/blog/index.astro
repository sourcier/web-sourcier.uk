---
import { getCollection } from "astro:content";
import { isPublished } from "../../utils/drafts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import MailingListCTA from "../../components/MailingListCTA.astro";
import BlogGrid from "../../components/BlogGrid.astro";
import BlogTagCloud from "../../components/BlogTagCloud.astro";

const PAGE_SIZE = 9;

const allPosts = (await getCollection("posts"))
  .filter(isPublished)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const posts = allPosts.slice(0, PAGE_SIZE);
const nextUrl = totalPages > 1 ? "/blog/page/2" : null;
---

<BaseLayout
  pageTitle="Blog — Sourcier"
  description="Writing on software engineering, architecture, technical leadership, and lessons learned from 20+ years in the craft."
>
  <PageHero
    kicker="Writing"
    title="Blog"
    subtitle="Software engineering, architecture, and lessons learned along the way."
  />

  <div class="blog-intro">
    <div class="container is-max-desktop">
      <blockquote class="blog-intro__quote">
        <p>
          This blog is where I share ideas, lessons learned, and practical
          insights from my experience in software engineering — system design,
          web development, technical leadership, and whatever else is on my
          mind.
        </p>
      </blockquote>
    </div>
  </div>

  <BlogGrid
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
    prevUrl={null}
    nextUrl={nextUrl}
  />

  <BlogTagCloud />

  <MailingListCTA />
</BaseLayout>

<style lang="scss">
  .blog-intro {
    padding: 3.5rem 1.5rem 0;
  }

  .blog-intro__quote {
    margin: 0;
    padding: 0 0 0 2rem;
    border-left: 3px solid var(--color-pink);
    position: relative;

    p {
      font-family: "Barlow Condensed", sans-serif;
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight: 700;
      line-height: 1.45;
      color: var(--color-ink);
      text-transform: uppercase;
      letter-spacing: 0.01em;
      margin: 0;
    }
  }
</style>
