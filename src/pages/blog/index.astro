---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost.astro";
import PageHero from "../../components/PageHero.astro";
const allPosts = (await getCollection("posts"))
  .filter((post) => !post.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const pageTitle = "Blog — Sourcier";
---

<BaseLayout
  pageTitle={pageTitle}
  description="Writing on software engineering, architecture, technical leadership, and lessons learned from 20+ years in the craft."
>
  <PageHero
    kicker="Writing"
    title="Blog"
    subtitle="Software engineering, architecture, and lessons learned along the way."
  />

  <div class="blog-intro">
    <div class="container is-max-desktop">
      <blockquote class="blog-intro__quote">
        <p>
          This blog is where I share ideas, lessons learned, and practical
          insights from my experience in software engineering — system design,
          web development, technical leadership, and whatever else is on my
          mind.
        </p>
      </blockquote>
    </div>
  </div>

  <section class="section">
    <div class="container is-max-desktop">
      <div
        class="fixed-grid has-1-cols-mobile has-3-cols-tablet has-3-cols-desktop"
      >
        <div class="grid">
          {
            allPosts.map((post: any) => (
              <div class="cell">
                <BlogPost
                  title={post.data.title}
                  subTitle={post.data.subTitle}
                  description={post.data.description}
                  url={`/blog/${post.id}`}
                  cover={post.data.cover}
                  draft={post.data.draft}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  .blog-intro {
    padding: 3.5rem 1.5rem 0;
  }

  .blog-intro__quote {
    margin: 0;
    padding: 0 0 0 2rem;
    border-left: 3px solid var(--color-pink);
    position: relative;

    p {
      font-family: "Barlow Condensed", sans-serif;
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight: 700;
      line-height: 1.45;
      color: var(--color-ink);
      text-transform: uppercase;
      letter-spacing: 0.01em;
      margin: 0;
    }
  }
</style>
