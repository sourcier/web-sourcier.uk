---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost.astro";
import PageHero from "../../components/PageHero.astro";
import MailingListCTA from "../../components/MailingListCTA.astro";
const allPosts = (await getCollection("posts"))
  .filter((post) => !post.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const pageTitle = "Blog — Sourcier";

const COLS = 3;
const MIN_CARDS = 6;
const total = Math.max(MIN_CARDS, Math.ceil(allPosts.length / COLS) * COLS);
const placeholderCount = total - allPosts.length;
---

<BaseLayout
  pageTitle={pageTitle}
  description="Writing on software engineering, architecture, technical leadership, and lessons learned from 20+ years in the craft."
>
  <PageHero
    kicker="Writing"
    title="Blog"
    subtitle="Software engineering, architecture, and lessons learned along the way."
  />

  <div class="blog-intro">
    <div class="container is-max-desktop">
      <blockquote class="blog-intro__quote">
        <p>
          This blog is where I share ideas, lessons learned, and practical
          insights from my experience in software engineering — system design,
          web development, technical leadership, and whatever else is on my
          mind.
        </p>
      </blockquote>
    </div>
  </div>

  <section class="section">
    <div class="container is-max-desktop">
      <div
        class="fixed-grid has-1-cols-mobile has-3-cols-tablet has-3-cols-desktop"
      >
        <div class="grid">
          {
            allPosts.map((post: any) => (
              <div class="cell">
                <BlogPost
                  title={post.data.title}
                  subTitle={post.data.subTitle}
                  description={post.data.description}
                  url={`/blog/${post.id}`}
                  cover={post.data.cover}
                  draft={post.data.draft}
                />
              </div>
            ))
          }
          {
            Array.from({ length: placeholderCount }).map(() => (
              <div class="cell">
                <div
                  class="card card__blog card__blog--placeholder"
                  aria-hidden="true"
                >
                  <div class="card__body">
                    <div class="skeleton-line skeleton-line--date" />
                    <div class="skeleton-line skeleton-line--title" />
                    <div class="skeleton-line skeleton-line--title skeleton-line--title-short" />
                    <div class="skeleton-line" />
                    <div class="skeleton-line" />
                    <div class="skeleton-line skeleton-line--short" />
                  </div>
                  <div class="card__cta card__cta--placeholder">
                    <div class="skeleton-line skeleton-line--cta" />
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <MailingListCTA />
</BaseLayout>

<style lang="scss">
  .blog-intro {
    padding: 3.5rem 1.5rem 0;
  }

  .blog-intro__quote {
    margin: 0;
    padding: 0 0 0 2rem;
    border-left: 3px solid var(--color-pink);
    position: relative;

    p {
      font-family: "Barlow Condensed", sans-serif;
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight: 700;
      line-height: 1.45;
      color: var(--color-ink);
      text-transform: uppercase;
      letter-spacing: 0.01em;
      margin: 0;
    }
  }

  @keyframes skeleton-shimmer {
    from {
      background-position: -400px 0;
    }
    to {
      background-position: 400px 0;
    }
  }

  .skeleton-line {
    height: 0.875rem;
    border-radius: 4px;
    margin-bottom: 0.6rem;
    background: linear-gradient(
      90deg,
      var(--color-border) 25%,
      var(--color-surface) 50%,
      var(--color-border) 75%
    );
    background-size: 400px 100%;
    animation: skeleton-shimmer 1.4s ease infinite;
    width: 100%;

    &--date {
      width: 30%;
      margin-bottom: 0.75rem;
    }
    &--title {
      height: 1.25rem;
      width: 90%;
    }
    &--title-short {
      width: 60%;
      margin-bottom: 0.75rem;
    }
    &--short {
      width: 50%;
    }
    &--cta {
      width: 5rem;
      height: 0.875rem;
    }
  }

  .card__blog--placeholder {
    pointer-events: none;
    opacity: 0.6;
  }

  .card__cta--placeholder {
    display: flex;
    align-items: center;
  }
</style>
