---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import MailingListCTA from "../../../components/MailingListCTA.astro";
import BlogGrid from "../../../components/BlogGrid.astro";

export async function getStaticPaths() {
  const PAGE_SIZE = 9;

  const allPosts = (await getCollection("posts"))
    .filter((post) => !post.data.draft || import.meta.env.DEV)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const pageNum = i + 2;
    const start = (pageNum - 1) * PAGE_SIZE;
    return {
      params: { page: String(pageNum) },
      props: {
        posts: allPosts.slice(start, start + PAGE_SIZE),
        currentPage: pageNum,
        totalPages,
        prevUrl: pageNum === 2 ? "/blog" : `/blog/page/${pageNum - 1}`,
        nextUrl: pageNum < totalPages ? `/blog/page/${pageNum + 1}` : null,
      },
    };
  });
}

const { posts, currentPage, totalPages, prevUrl, nextUrl } = Astro.props;
---

<BaseLayout
  pageTitle={`Blog — Page ${currentPage} — Sourcier`}
  description="Writing on software engineering, architecture, technical leadership, and lessons learned from 20+ years in the craft."
>
  <PageHero
    kicker="Writing"
    title="Blog"
    subtitle="Software engineering, architecture, and lessons learned along the way."
  />

  <BlogGrid
    posts={posts}
    currentPage={currentPage}
    totalPages={totalPages}
    prevUrl={prevUrl}
    nextUrl={nextUrl}
  />

  <MailingListCTA />
</BaseLayout>
