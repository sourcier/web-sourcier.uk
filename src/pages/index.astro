---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import MailingListCTA from "../components/MailingListCTA.astro";
import Testimonials from "../components/Testimonials.astro";

const allPosts = (await getCollection("posts"))
  .filter((post) => !post.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const GRID_SIZE = 6;
const placeholderCount = Math.max(0, GRID_SIZE - allPosts.length);
---

<BaseLayout
  pageTitle="Sourcier — Software Engineering by Roger Rajaratnam"
  description="London-based software engineer and technical lead. Writing about engineering, architecture, and technical leadership."
>
  <section class="hero-intro">
    <div class="container">
      <div class="columns is-vcentered">
        <div class="column">
          <span class="hero-kicker">Software Engineer &amp; Technical Lead</span
          >
          <h1 class="hero-title">Hi, I'm Roger<br />Rajaratnam</h1>
          <p class="hero-bio">
            London-based engineer building scalable web systems, mentoring
            developers, and sharing real-world lessons from a decade in the
            craft.
          </p>
          <div class="buttons mt-5">
            <a href="/blog" class="button is-primary is-medium">Read the blog</a
            >
            <a href="/about" class="button is-light is-medium">About me</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-label="Recent Posts">
    <div class="container is-max-desktop">
      <p class="section-label">Recent Posts</p>
      <div
        class="fixed-grid has-1-cols-mobile has-3-cols-tablet has-3-cols-desktop"
      >
        <div class="grid">
          {
            allPosts.map((post: any) => (
              <div class="cell">
                <BlogPost
                  title={post.data.title}
                  subTitle={post.data.subTitle}
                  description={post.data.description}
                  url={`/blog/${post.id}`}
                  cover={post.data.cover}
                  pubDate={post.data.pubDate}
                  draft={post.data.draft}
                />
              </div>
            ))
          }
          {
            Array.from({ length: placeholderCount }).map(() => (
              <div class="cell">
                <div
                  class="card card__blog card__blog--placeholder"
                  aria-hidden="true"
                >
                  <div class="card__blog--placeholder-inner">
                    <span class="card__blog--placeholder-label">
                      More posts coming soon
                    </span>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <Testimonials />
  <MailingListCTA />
</BaseLayout>

<style lang="scss">
  .card__blog--placeholder {
    pointer-events: none;
    border: 2px dashed var(--color-border);
    border-top: 2px dashed var(--color-border);
    background: transparent;
    box-shadow: none;

    &-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1;
      padding: 2rem 1.5rem;
    }

    &-label {
      font-family: "Barlow Condensed", sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-border);
    }
  }
</style>
