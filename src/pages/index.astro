---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import avatarImage from "../../assets/images/avatar.jpeg";
const pageTitle = "Home Page";
const allPosts = (await getCollection("posts"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout pageTitle={pageTitle}>
  <section class="section">
    <div class="container">
      <h1 class="title">Latest Blog Posts</h1>
      <h2 class="subtitle">
        Sharing insights and lessons from the world of software engineering.
      </h2>
      <div
        class="fixed-grid has-1-cols-mobile has-3-cols-tablet has-3-cols-desktop"
      >
        <div class="grid">
          <BlogPost
            title="About Me"
            subTitle="Engineer, builder, and mentor"
            description="Learn more about me, a London-based software engineer and technical lead who enjoys building scalable web applications, mentoring developers, and sharing lessons from real-world software engineering."
            url="/about"
            cover={{ image: { src: avatarImage.src, alt: "Avatar image" } }}
          />
          {
            allPosts.map((post: any) => (
              <div class="cell">
                <BlogPost
                  title={post.data.title}
                  subTitle={post.data.subTitle}
                  description={post.data.description}
                  url={`/blog/${post.id}`}
                  cover={post.data.cover}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
