---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import MailingListCTA from "../components/MailingListCTA.astro";
import Testimonials from "../components/Testimonials.astro";

const allPosts = (await getCollection("posts"))
  .filter((post) => !post.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const GRID_SIZE = 6;
const placeholderCount = Math.max(0, GRID_SIZE - allPosts.length);
---

<BaseLayout
  pageTitle="Sourcier — Software Engineering by Roger Rajaratnam"
  description="London-based software engineer and technical lead. Writing about engineering, architecture, and technical leadership."
>
  <section class="hero-intro">
    <div class="container">
      <div class="columns is-vcentered">
        <div class="column">
          <span class="hero-kicker">Software Engineer &amp; Technical Lead</span
          >
          <h1 class="hero-title">Hi, I'm Roger<br />Rajaratnam</h1>
          <p class="hero-bio">
            London-based engineer building scalable web systems, mentoring
            developers, and sharing real-world lessons from a decade in the
            craft.
          </p>
          <div class="buttons mt-5">
            <a href="/blog" class="button is-primary is-medium">Read the blog</a
            >
            <a href="/about" class="button is-light is-medium">About me</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-label="Recent Posts">
    <div class="container is-max-desktop">
      <p class="section-label">Recent Posts</p>
      <div
        class="fixed-grid has-1-cols-mobile has-3-cols-tablet has-3-cols-desktop"
      >
        <div class="grid">
          {
            allPosts.map((post: any) => (
              <div class="cell">
                <BlogPost
                  title={post.data.title}
                  subTitle={post.data.subTitle}
                  description={post.data.description}
                  url={`/blog/${post.id}`}
                  cover={post.data.cover}
                  pubDate={post.data.pubDate}
                  draft={post.data.draft}
                />
              </div>
            ))
          }
          {
            Array.from({ length: placeholderCount }).map(() => (
              <div class="cell">
                <div
                  class="card card__blog card__blog--placeholder"
                  aria-hidden="true"
                >
                  <div class="card__body">
                    <div class="skeleton-line skeleton-line--date" />
                    <div class="skeleton-line skeleton-line--title" />
                    <div class="skeleton-line skeleton-line--title skeleton-line--title-short" />
                    <div class="skeleton-line" />
                    <div class="skeleton-line" />
                    <div class="skeleton-line skeleton-line--short" />
                  </div>
                  <div class="card__cta card__cta--placeholder">
                    <div class="skeleton-line skeleton-line--cta" />
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <Testimonials />
  <MailingListCTA />
</BaseLayout>

<style lang="scss">
  @keyframes skeleton-shimmer {
    from {
      background-position: -400px 0;
    }
    to {
      background-position: 400px 0;
    }
  }

  .skeleton-line {
    height: 0.875rem;
    border-radius: 4px;
    margin-bottom: 0.6rem;
    background: linear-gradient(
      90deg,
      var(--color-border) 25%,
      var(--color-surface) 50%,
      var(--color-border) 75%
    );
    background-size: 400px 100%;
    animation: skeleton-shimmer 1.4s ease infinite;
    width: 100%;

    &--date {
      width: 30%;
      margin-bottom: 0.75rem;
    }
    &--title {
      height: 1.25rem;
      width: 90%;
    }
    &--title-short {
      width: 60%;
      margin-bottom: 0.75rem;
    }
    &--short {
      width: 50%;
    }
    &--cta {
      width: 5rem;
      height: 0.875rem;
    }
  }

  .card__blog--placeholder {
    pointer-events: none;
    opacity: 0.6;
  }

  .card__cta--placeholder {
    display: flex;
    align-items: center;
  }
</style>
