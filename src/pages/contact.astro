---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
const pageTitle = "Contact";
---

<BaseLayout pageTitle={pageTitle}>
  <PageHero
    kicker="Get in touch"
    title="Contact"
    subtitle="Got a question, a project idea, or just want to say hello? I'd love to hear from you."
  />

  <section class="section">
    <div class="container is-max-desktop">
      <div class="contact-layout">
        <div class="contact-form-col">
          <form
            class="contact-form"
            name="Contact"
            method="post"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <div class="contact-form__row">
              <div class="contact-form__field">
                <label class="contact-form__label" for="contact-name"
                  >Name</label
                >
                <input
                  class="contact-form__input"
                  id="contact-name"
                  type="text"
                  placeholder="Your name"
                  name="name"
                  required
                />
              </div>
              <div class="contact-form__field">
                <label class="contact-form__label" for="contact-email"
                  >Email</label
                >
                <input
                  class="contact-form__input"
                  id="contact-email"
                  type="email"
                  placeholder="your@email.com"
                  name="email"
                  required
                />
              </div>
            </div>

            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-subject"
                >Subject</label
              >
              <input
                class="contact-form__input"
                id="contact-subject"
                type="text"
                placeholder="What's this about?"
                name="subject"
                required
              />
            </div>

            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-message"
                >Message</label
              >
              <textarea
                class="contact-form__textarea"
                id="contact-message"
                placeholder="Your message…"
                name="message"
                rows="6"
                required></textarea>
            </div>

            <div class="field is-hidden" aria-hidden="true">
              <input name="bot-field" type="text" />
            </div>

            <button class="contact-form__submit" type="submit"
              >Send Message &rarr;</button
            >
          </form>

          <div class="contact-success is-hidden" data-success-message>
            <p class="contact-success__text">
              &#10003; Message sent — I'll get back to you soon.
            </p>
            <button class="contact-success__close" type="button">Dismiss</button
            >
          </div>
        </div>

        <aside class="contact-sidebar">
          <h2 class="contact-sidebar__heading">Find me online</h2>
          <div class="contact-sidebar__links">
            <a
              class="contact-sidebar__link"
              href="https://www.linkedin.com/in/roger-rajaratnam"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="contact-sidebar__link-label">LinkedIn</span>
              <span class="contact-sidebar__link-desc"
                >Software engineering &amp; leadership</span
              >
            </a>
            <a
              class="contact-sidebar__link"
              href="https://github.com/sourcier"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="contact-sidebar__link-label">GitHub</span>
              <span class="contact-sidebar__link-desc"
                >Open source &amp; blog code</span
              >
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const handleSubmit = (event: Event) => {
    event.preventDefault();

    const form = event.target as HTMLFormElement;
    const formData = new FormData(form) as unknown as Record<string, string>;

    fetch("/", {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded" },
      body: new URLSearchParams(formData).toString(),
    })
      .then(() => {
        form.reset();
        form.style.display = "none";
        document
          .querySelector("[data-success-message]")
          ?.classList.remove("is-hidden");
      })
      .catch((error) => alert(error));
  };

  const handleSuccessMessageClose = () => {
    const form = document.querySelector(
      "form[name='Contact']",
    ) as HTMLFormElement;
    const successMessage = document.querySelector(
      "[data-success-message]",
    ) as HTMLElement;

    form.style.display = "";
    successMessage.classList.add("is-hidden");
  };

  document
    .querySelector("form[name='Contact']")
    ?.addEventListener("submit", handleSubmit);

  document
    .querySelector("[data-success-message] .contact-success__close")
    ?.addEventListener("click", handleSuccessMessageClose);
</script>
