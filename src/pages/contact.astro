---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Contact";
---

<BaseLayout pageTitle={pageTitle}>
  <header class="post__header">
    <div class="container">
      <div class="post__header-inner">
        <p class="hero-kicker">Get in touch</p>
        <h1 class="post__title">Contact</h1>
        <p class="post__subtitle">
          Got a question, a project idea, or just want to say hello? I'd love to
          hear from you.
        </p>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <section class="section">
        <form
          name="Contact"
          method="post"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <div class="field">
            <label class="label">Email</label>
            <div class="control">
              <input
                class="input"
                type="email"
                placeholder="Your email"
                name="email"
                required
              />
            </div>
          </div>

          <div class="field">
            <label class="label">Name</label>
            <div class="control">
              <input
                class="input"
                type="text"
                placeholder="Your name"
                name="name"
                required
              />
            </div>
          </div>

          <div class="field">
            <label class="label">Subject</label>
            <div class="control">
              <input
                class="input"
                type="text"
                placeholder="Your subject"
                name="subject"
                required
              />
            </div>
          </div>

          <div class="field">
            <label class="label">Message</label>
            <div class="control">
              <textarea
                class="textarea"
                placeholder="Your message"
                name="message"
                required></textarea>
            </div>
          </div>
          <div class="field is-hidden">
            <label class="label"> Don't fill this out if you're human:</label>
            <div class="control">
              <input name="bot-field" type="text" class="input" />
            </div>
          </div>
          <div class="field">
            <div class="control">
              <button class="button is-primary">Send Message</button>
            </div>
          </div>
        </form>
        <div
          class="notification is-success mt-3 is-hidden"
          data-success-message
        >
          <button class="delete"></button>
          Thank you for your message! I'll get back to you as soon as I can.
        </div>
      </section>
      <section class="section">
        <div class="content post__content">
          <h2>Socials</h2>
          <p>
            You can also find me on
            <a
              href="https://www.linkedin.com/in/roger-rajaratnam"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a> where I share thoughts on software engineering, system design, and
            technical leadership. If you're interested in seeing what I'm building
            or exploring, head over to
            <a
              href="https://github.com/sourcier"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a> where I contribute to open source projects and share code from my
            blog posts.
          </p>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<script>
  const handleSubmit = (event: Event) => {
    event.preventDefault();

    const form = event.target as HTMLFormElement;
    const formData = new FormData(form) as unknown as Record<string, string>;

    fetch("/", {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded" },
      body: new URLSearchParams(formData).toString(),
    })
      .then(() => {
        form.reset();
        form.style.display = "none";
        document
          .querySelector("[data-success-message]")
          ?.classList.remove("is-hidden");
      })
      .catch((error) => alert(error));
  };

  const handleSuccessMessageClose = (event: Event) => {
    const form = document.querySelector(
      "form[name='Contact']",
    ) as HTMLFormElement;
    const successMessage = document.querySelector(
      "[data-success-message]",
    ) as HTMLElement;

    form.style.display = "block";
    successMessage.classList.toggle("is-hidden");
  };

  document
    .querySelector("form[name='Contact']")
    ?.addEventListener("submit", handleSubmit);

  document
    .querySelector("[data-success-message] .delete")
    ?.addEventListener("click", handleSuccessMessageClose);
</script>
