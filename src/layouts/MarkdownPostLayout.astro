---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
const formattedDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<BaseLayout pageTitle={frontmatter.title}>
  <article class="post">
    <header
      class="post__header"
      style={frontmatter.cover
        ? `--cover-image: url('${frontmatter.cover.image.src}')`
        : ""}
      data-has-cover={frontmatter.cover ? "true" : "false"}
    >
      <div class="container">
        <div class="post__header-inner">
          <div class="post__tags">
            {
              frontmatter.tags.map((tag: string) => (
                <a href={`/tags/${tag}`} class="post__tag">
                  {tag}
                </a>
              ))
            }
          </div>
          <h1 class="post__title">{frontmatter.title}</h1>
          {
            frontmatter.subTitle && (
              <p class="post__subtitle">{frontmatter.subTitle}</p>
            )
          }
          <div class="post__meta">
            <span class="post__author">{frontmatter.author}</span>
            {formattedDate && <span class="post__date">{formattedDate}</span>}
          </div>
        </div>
      </div>
    </header>

    <div class="post__body">
      <div class="container">
        <div class="post__content content">
          <slot />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
