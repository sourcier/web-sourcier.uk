---
import BaseLayout from "./BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Comments from "../components/Comments.astro";
import PageHistory from "../components/PageHistory.astro";
import PageCredits from "../components/PageCredits.astro";
import SharePost from "../components/SharePost.astro";
import MailingListCTA from "../components/MailingListCTA.astro";
import SponsorCTA from "../components/SponsorCTA.astro";

import TagsSidebar from "../components/TagsSidebar.astro";
const { frontmatter, postId, headings = [] } = Astro.props;
const tocHeadings = (
  headings as { depth: number; slug: string; text: string }[]
).filter((h) => h.depth === 2 || h.depth === 3);
const formattedDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
      day: "numeric",
      timeZone: "Europe/London",
    })
  : null;

const ogImage = frontmatter.cover?.image?.src ?? undefined;
const pageTitle = `${frontmatter.title} — Sourcier`;

const thumbSrc = frontmatter.cover?.thumbnail
  ? `/search-thumbnails/${postId}/${postId}-thumbnail.webp`
  : null;
---

<BaseLayout
  pageTitle={pageTitle}
  description={frontmatter.description}
  ogImage={ogImage}
  ogType="article"
  pubDate={frontmatter.pubDate}
  author={frontmatter.author}
  tags={frontmatter.tags}
>
  <script
    is:inline
    defer
    src="https://cdn.jsdelivr.net/npm/mermaid@11.13.0/dist/mermaid.min.js"
    slot="head"></script>
  <article class="post" data-pagefind-body>
    <span data-pagefind-meta="title" class="visually-hidden"
      >{frontmatter.title}</span
    >
    {
      thumbSrc && (
        <img
          data-pagefind-meta="image[src]"
          src={thumbSrc}
          width="96"
          height="96"
          alt=""
          aria-hidden="true"
          class="visually-hidden"
        />
      )
    }
    <PageHero
      title={frontmatter.title}
      subtitle={frontmatter.subTitle}
      coverImage={frontmatter.cover
        ? { src: frontmatter.cover.image.src }
        : undefined}
      tags={frontmatter.tags}
      author={frontmatter.author}
      date={formattedDate ?? undefined}
      crumbs={[{ label: "Blog", href: "/blog" }, { label: frontmatter.title }]}
      shareUrl={Astro.url.href}
      shareTitle={frontmatter.title}
    />

    <div class="post__body">
      <div class="post__layout">
        <div class="post__layout__content">
          <div class="post__content content">
            <slot />
          </div>
        </div>
        <aside class="post__sidebar" aria-label="Post sidebar">
          {
            tocHeadings.length > 1 && (
              <nav class="toc">
                <p class="toc__heading">On this page</p>
                <ol class="toc__list">
                  {tocHeadings.map((h) => (
                    <li class={`toc__item toc__item--h${h.depth}`}>
                      <a class="toc__link" href={`#${h.slug}`}>
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            )
          }
          <SharePost title={frontmatter.title} url={Astro.url.href} vertical />
          <SponsorCTA sidebar />
          <TagsSidebar />
        </aside>
      </div>
    </div>

    <div class="sponsor-cta-below-post">
      <SponsorCTA />
    </div>
    <MailingListCTA />
    {postId && <Comments postId={postId} />}
    {
      (frontmatter.history?.length > 0 || frontmatter.credits?.length > 0) && (
        <section
          class="post-meta-section"
          aria-label="Page credits and history"
        >
          <div class="post-meta-section__inner">
            {frontmatter.credits && frontmatter.credits.length > 0 && (
              <PageCredits entries={frontmatter.credits} />
            )}
            {frontmatter.history && frontmatter.history.length > 0 && (
              <PageHistory entries={frontmatter.history} />
            )}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  :global(.mermaid-diagram),
  :global(.zoomable-image) {
    position: relative;
    margin: 2rem 0;
    display: flex;
    justify-content: center;
    overflow-x: auto;
    border: 1px solid var(--color-border);
    background: #fafafa;
    padding: 2rem 1.5rem;
  }

  :global(.zoomable-image img) {
    outline: none;
    margin: 0;
  }

  :global([data-theme="dark"] .mermaid-diagram),
  :global([data-theme="dark"] .zoomable-image) {
    background: #282c34;
  }

  :global(.media-expand-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.25);
    border-radius: 0;
    color: rgba(0, 0, 0, 0.5);
    cursor: pointer;
    transition:
      opacity 0.2s ease,
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }

  :global([data-theme="dark"] .media-expand-btn) {
    border-color: rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.5);
  }

  @media (hover: hover) {
    :global(.media-expand-btn) {
      opacity: 0;
    }

    :global(.mermaid-diagram:hover .media-expand-btn:not(:hover)),
    :global(.zoomable-image:hover .media-expand-btn:not(:hover)) {
      opacity: 0.75;
    }

    :global(.media-expand-btn:hover) {
      opacity: 1;
    }
  }

  :global(.media-expand-btn:hover) {
    background: rgba(232, 0, 106, 0.1);
    border-color: rgba(232, 0, 106, 0.5);
    color: #e8006a;
  }

  :global(.media-lightbox) {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.85);
    align-items: center;
    justify-content: center;
    padding: 2rem;

    &.is-open {
      display: flex;
    }
  }

  :global(.media-lightbox__inner) {
    position: relative;
    background: #fafafa;
    width: 98vw;
    max-width: 98vw;
    height: 94vh;
    max-height: 94vh;

    &::after {
      content: "scroll for more ↓";
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 5rem;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding-bottom: 0.75rem;
      pointer-events: none;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      color: rgba(0, 0, 0, 0.45);
      background: linear-gradient(
        to bottom,
        transparent,
        rgba(250, 250, 250, 1)
      );
      transition: opacity 0.2s ease;
    }

    &.is-scrolled-end::after {
      opacity: 0;
    }
  }

  :global(.media-lightbox__scroll) {
    width: 100%;
    height: 100%;
    overflow: auto;
    padding: 2rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  :global(.media-lightbox__content) {
    margin: auto;
    flex-shrink: 0;
  }

  :global([data-theme="dark"] .media-lightbox__inner) {
    background: #282c34;
  }

  :global([data-theme="dark"] .media-lightbox__inner::after) {
    color: rgba(255, 255, 255, 0.35);
    background: linear-gradient(to bottom, transparent, rgba(40, 44, 52, 1));
  }

  :global(.media-lightbox__close) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.25);
    border-radius: 0;
    color: rgba(0, 0, 0, 0.5);
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }

  :global([data-theme="dark"] .media-lightbox__close) {
    border-color: rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.5);
  }

  :global(.media-lightbox__close:hover) {
    background: rgba(232, 0, 106, 0.1);
    border-color: rgba(232, 0, 106, 0.5);
    color: #e8006a;
  }

  :global(.mermaid-diagram[data-loading]) {
    min-height: 180px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.75rem;
    color: transparent; /* prevents definition text flashing between skeleton and SVG */
  }

  :global(.zoomable-image[data-loading]) {
    min-height: 260px;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  :global(.zoomable-image[data-loading])::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--color-border) 25%,
      rgba(232, 0, 106, 0.1) 50%,
      var(--color-border) 75%
    );
    background-size: 600px 100%;
    animation: mermaid-skeleton-shimmer 1.6s ease-in-out infinite;
  }

  /* Skeleton fades out fast; image then fades in on its own via base transition */
  :global(.zoomable-image[data-loading].is-loaded)::before {
    animation: expandable-fade-out 0.25s ease forwards;
  }

  :global(.zoomable-image__icon) {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    z-index: 1;
    opacity: 0.25;
    color: currentColor;
    pointer-events: none;
  }

  :global(.zoomable-image[data-loading].is-loaded .zoomable-image__icon) {
    animation: expandable-fade-out 0.2s ease forwards;
  }

  :global(.zoomable-image__icon svg) {
    display: block;
  }

  :global([data-theme="dark"] .zoomable-image[data-loading])::before {
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.05) 25%,
      rgba(232, 0, 106, 0.12) 50%,
      rgba(255, 255, 255, 0.05) 75%
    );
    background-size: 600px 100%;
  }

  /* Transition on base selector so it fires reliably when data-loading is removed */
  :global(.zoomable-image img.zoomable) {
    transition: opacity 0.5s ease;
  }

  :global(.zoomable-image[data-loading] img) {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.zoomable-image img.zoomable) {
      transition: none;
    }
  }

  :global(.mermaid-skeleton) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 480px;
  }

  :global(.mermaid-skeleton__row) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
  }

  :global(.mermaid-skeleton__node) {
    height: 2.25rem;
    flex: 1;
    max-width: 140px;
    border-radius: 3px;
    background: linear-gradient(
      90deg,
      var(--color-border) 25%,
      rgba(232, 0, 106, 0.12) 50%,
      var(--color-border) 75%
    );
    background-size: 400px 100%;
    animation: mermaid-skeleton-shimmer 1.6s ease-in-out infinite;
  }

  :global(.mermaid-skeleton__node--wide) {
    max-width: 220px;
  }

  :global(.mermaid-skeleton__node--narrow) {
    max-width: 90px;
  }

  :global(.mermaid-skeleton__connector) {
    width: 2px;
    height: 1.5rem;
    background: var(--color-border);
    border-radius: 1px;
    opacity: 0.6;
  }

  :global([data-theme="dark"] .mermaid-skeleton__node) {
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.06) 25%,
      rgba(232, 0, 106, 0.15) 50%,
      rgba(255, 255, 255, 0.06) 75%
    );
    background-size: 400px 100%;
  }

  :global(.mermaid-diagram svg) {
    max-width: 100%;
    height: auto;
  }

  :global(.mermaid-diagram text) {
    fill: var(--color-ink) !important;
  }

  :global(.mermaid-diagram .messageText),
  :global(.mermaid-diagram .labelText),
  :global(.mermaid-diagram .loopText),
  :global(.mermaid-diagram .noteText) {
    fill: var(--color-ink) !important;
    stroke: none !important;
  }

  :global(.mermaid-diagram line),
  :global(.mermaid-diagram path.arrowMarkerPath) {
    stroke: var(--color-ink) !important;
  }

  :global(.mermaid-diagram .messageLine0),
  :global(.mermaid-diagram .messageLine1) {
    stroke: var(--color-ink) !important;
  }
</style>

<script>
  // Mermaid diagrams — rendered client-side from fenced ```mermaid blocks
  import type { MermaidConfig } from "mermaid";
  import { faCircleXmark, faExpand } from "@fortawesome/free-solid-svg-icons";

  const toSvgIcon = (iconDef: typeof faExpand, size = 14): string => {
    const [width, height, , , pathData] = iconDef.icon;
    const paths = Array.isArray(pathData) ? pathData : [pathData];
    const pathElements = paths.map((d) => `<path d="${d}"/>`).join("");
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 ${width} ${height}" fill="currentColor" aria-hidden="true">${pathElements}</svg>`;
  };

  const ICON_EXPAND = toSvgIcon(faExpand);
  const ICON_XMARK = toSvgIcon(faCircleXmark);

  function getMermaidConfig(isDark: boolean): MermaidConfig {
    return {
      startOnLoad: false,
      theme: "base",
      darkMode: isDark,
      look: "handDrawn",
      themeVariables: isDark
        ? {
            background: "#282c34",
            primaryColor: "#3d1528",
            primaryTextColor: "#abb2bf",
            primaryBorderColor: "rgba(232, 0, 106, 0.4)",
            lineColor: "#767c89",
            secondaryColor: "#2c313a",
            tertiaryColor: "#282c34",
            edgeLabelBackground: "#282c34",
            clusterBkg: "#2c313a",
            titleColor: "#dcdcdc",
            nodeTextColor: "#abb2bf",
            fontFamily: '"Barlow Condensed", sans-serif',
          }
        : {
            background: "#fafafa",
            primaryColor: "#fce8f2",
            primaryTextColor: "#383a42",
            primaryBorderColor: "rgba(232, 0, 106, 0.3)",
            lineColor: "#6b6b6b",
            secondaryColor: "#f0f0f0",
            tertiaryColor: "#fafafa",
            edgeLabelBackground: "#fafafa",
            clusterBkg: "#f0f0f0",
            titleColor: "#383a42",
            nodeTextColor: "#383a42",
            fontFamily: '"Barlow Condensed", sans-serif',
          },
    };
  }

  // Lightbox — created once, shared across all diagrams and images
  const lightbox = document.createElement("div");
  lightbox.className = "media-lightbox";
  lightbox.setAttribute("role", "dialog");
  lightbox.setAttribute("aria-modal", "true");
  lightbox.setAttribute("aria-label", "Diagram fullscreen view");
  const lightboxInner = document.createElement("div");
  lightboxInner.className = "media-lightbox__inner";
  const lightboxScroll = document.createElement("div");
  lightboxScroll.className = "media-lightbox__scroll";
  const closeBtn = document.createElement("button");
  closeBtn.className = "media-lightbox__close";
  closeBtn.innerHTML = ICON_XMARK;
  closeBtn.setAttribute("aria-label", "Close fullscreen diagram");
  lightboxInner.appendChild(lightboxScroll);
  lightboxInner.appendChild(closeBtn);
  lightbox.appendChild(lightboxInner);
  document.body.appendChild(lightbox);

  const closeLightbox = () => {
    lightbox.classList.remove("is-open");
    lightboxScroll.querySelector(".media-lightbox__content")?.remove();
    document.documentElement.style.overflow = "";
    document.body.style.overflow = "";
  };

  const updateScrollHint = () => {
    const atBottom =
      lightboxScroll.scrollHeight - lightboxScroll.scrollTop <=
      lightboxScroll.clientHeight + 4; // 4px tolerance for sub-pixel browser rounding
    lightboxInner.classList.toggle("is-scrolled-end", atBottom);
  };

  lightboxScroll.addEventListener("scroll", updateScrollHint, {
    passive: true,
  });

  closeBtn.addEventListener("click", closeLightbox);
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });

  // Store {definition, expandBtn} keyed by container for theme re-render
  const definitions = new Map<
    HTMLElement,
    { definition: string; btn: HTMLButtonElement }
  >();

  document
    .querySelectorAll<HTMLElement>(
      ".post__content .mermaid-diagram[data-mermaid]",
    )
    .forEach((container) => {
      const definition = container.dataset.mermaid!;

      const expandBtn = document.createElement("button");
      expandBtn.className = "media-expand-btn";
      expandBtn.innerHTML = ICON_EXPAND;
      expandBtn.setAttribute("aria-label", "View diagram fullscreen");

      expandBtn.addEventListener("click", () => {
        const svgClone = container
          .querySelector("svg")!
          .cloneNode(true) as SVGElement;
        svgClone.classList.add("media-lightbox__content");
        svgClone.removeAttribute("style");
        svgClone.removeAttribute("width");
        svgClone.removeAttribute("height");
        svgClone.style.display = "block";
        const viewBoxAttr = svgClone.getAttribute("viewBox");
        if (viewBoxAttr) {
          const parts = viewBoxAttr
            .trim()
            .split(/[\s,]+/)
            .map(Number);
          if (parts.length === 4 && parts[2] > 0 && parts[3] > 0) {
            const rem = parseFloat(
              getComputedStyle(document.documentElement).fontSize,
            );
            const availW = window.innerWidth * 0.98 - 4 * rem;
            const availH = window.innerHeight * 0.94 - 4 * rem;
            const scale = Math.min(availW / parts[2], availH / parts[3]);
            svgClone.style.width = `${Math.round(parts[2] * scale)}px`;
            svgClone.style.height = `${Math.round(parts[3] * scale)}px`;
          } else {
            svgClone.style.width = "100%";
            svgClone.style.height = "auto";
          }
        } else {
          svgClone.style.width = "100%";
          svgClone.style.height = "auto";
        }
        lightboxScroll.appendChild(svgClone);
        lightboxScroll.scrollTop = 0;
        lightbox.classList.add("is-open");
        document.documentElement.style.overflow = "hidden";
        document.body.style.overflow = "hidden";
        updateScrollHint();
        closeBtn.focus();
      });

      definitions.set(container, { definition, btn: expandBtn });
    });

  // Image expand — wrapper div is injected at build time by rehype-zoomable-images
  document
    .querySelectorAll<HTMLImageElement>(".post__content img.zoomable")
    .forEach((imgEl) => {
      const wrapper = imgEl.parentElement!;

      // Icon is stamped into the HTML at build time by rehype-zoomable-images
      const placeholder = wrapper.querySelector(".zoomable-image__icon");

      const revealImage = (animate = true) => {
        if (!animate) {
          wrapper.removeAttribute("data-loading");
          placeholder?.remove();
          return;
        }
        wrapper.classList.add("is-loaded");
        // After skeleton fades out (0.25s), remove data-loading → image's base
        // transition (0.5s) fires naturally as opacity goes 0 → 1
        setTimeout(() => {
          wrapper.removeAttribute("data-loading");
          wrapper.classList.remove("is-loaded");
          placeholder?.remove();
        }, 280);
      };
      if (imgEl.complete) {
        revealImage(false);
      } else {
        imgEl.addEventListener("load", () => revealImage(true), { once: true });
        imgEl.addEventListener("error", () => revealImage(false), {
          once: true,
        });
      }

      const expandBtn = document.createElement("button");
      expandBtn.className = "media-expand-btn";
      expandBtn.innerHTML = ICON_EXPAND;
      expandBtn.setAttribute("aria-label", "View image fullscreen");

      expandBtn.addEventListener("click", () => {
        const imgClone = document.createElement("img");
        imgClone.src = imgEl.src;
        imgClone.alt = imgEl.alt;
        imgClone.className = "media-lightbox__content";
        imgClone.style.display = "block";
        const rem = parseFloat(
          getComputedStyle(document.documentElement).fontSize,
        );
        const availW = window.innerWidth * 0.98 - 4 * rem;
        const availH = window.innerHeight * 0.94 - 4 * rem;
        const nw = imgEl.naturalWidth;
        const nh = imgEl.naturalHeight;
        if (nw > 0 && nh > 0) {
          const scale = Math.min(availW / nw, availH / nh);
          imgClone.style.width = `${Math.round(nw * scale)}px`;
          imgClone.style.height = `${Math.round(nh * scale)}px`;
        } else {
          imgClone.style.width = "100%";
          imgClone.style.height = "auto";
        }
        lightboxScroll.appendChild(imgClone);
        lightboxScroll.scrollTop = 0;
        lightbox.classList.add("is-open");
        document.documentElement.style.overflow = "hidden";
        document.body.style.overflow = "hidden";
        updateScrollHint();
        closeBtn.focus();
      });

      wrapper.appendChild(expandBtn);
    });

  async function renderDiagrams() {
    // Poll for mermaid — on slow connections the CDN defer script may not have executed yet
    const mermaid = await new Promise<any>((resolve) => {
      if ((window as any).mermaid) {
        resolve((window as any).mermaid);
        return;
      }
      const id = setInterval(() => {
        if ((window as any).mermaid) {
          clearInterval(id);
          resolve((window as any).mermaid);
        }
      }, 10);
    });
    const isDark = document.documentElement.dataset.theme === "dark";
    mermaid.initialize(getMermaidConfig(isDark));

    // Replace skeleton with definition text — mermaid.run() will replace it with SVG
    definitions.forEach(({ definition }, container) => {
      container.removeAttribute("data-processed");
      container.setAttribute("data-loading", "");
      container.textContent = definition;
    });

    await mermaid.run({ nodes: [...definitions.keys()] });

    definitions.forEach(({ btn }, container) => {
      container.removeAttribute("data-loading");
      container.appendChild(btn);
    });
  }

  await renderDiagrams();

  // Re-render diagrams when the theme changes (Header.astro uses setAttribute)
  new MutationObserver(async (mutations) => {
    for (const m of mutations) {
      if (m.attributeName === "data-theme") {
        await renderDiagrams();
        break;
      }
    }
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // Highlight the active ToC link as the user scrolls
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc__link");
  if (tocLinks.length) {
    const setActive = (id: string) => {
      tocLinks.forEach((l) =>
        l.classList.toggle("is-active", l.getAttribute("href") === `#${id}`),
      );
    };

    const headingEls = document.querySelectorAll<HTMLElement>(
      ".post__content h2, .post__content h3",
    );
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: "0px 0px -80% 0px" },
    );
    headingEls.forEach((h) => obs.observe(h));
  }
</script>
