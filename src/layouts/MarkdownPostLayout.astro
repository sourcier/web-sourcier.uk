---
import BaseLayout from "./BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Comments from "../components/Comments.astro";
import PageHistory from "../components/PageHistory.astro";
const { frontmatter, postId, headings = [] } = Astro.props;
const tocHeadings = (headings as { depth: number; slug: string; text: string }[]).filter(
  (h) => h.depth === 2 || h.depth === 3
);
const formattedDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

const ogImage = frontmatter.cover?.image?.src ?? undefined;
const pageTitle = `${frontmatter.title} — Sourcier`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={frontmatter.description}
  ogImage={ogImage}
  ogType="article"
  pubDate={frontmatter.pubDate}
  author={frontmatter.author}
  tags={frontmatter.tags}
>
  <article class="post">
    <PageHero
      title={frontmatter.title}
      subtitle={frontmatter.subTitle}
      coverImage={frontmatter.cover
        ? { src: frontmatter.cover.image.src }
        : undefined}
      tags={frontmatter.tags}
      author={frontmatter.author}
      date={formattedDate ?? undefined}
    />

    <div class="post__body">
      <div class="post__layout">
        <div class="post__layout__content">
          <div class="post__content content">
            <slot />
          </div>
          {
            frontmatter.history && frontmatter.history.length > 0 && (
              <div class="post__content">
                <PageHistory entries={frontmatter.history} />
              </div>
            )
          }
        </div>
        {tocHeadings.length > 1 && (
          <aside class="post__sidebar" aria-label="Table of contents">
            <nav class="toc">
              <p class="toc__heading">On this page</p>
              <ol class="toc__list">
                {tocHeadings.map((h) => (
                  <li class={`toc__item toc__item--h${h.depth}`}>
                    <a class="toc__link" href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )}
      </div>
    </div>

    {postId && <Comments postId={postId} />}
  </article>
</BaseLayout>

<style>
  :global(.post__content pre) {
    position: relative;
  }

  :global(.code-lang-label) {
    position: absolute;
    top: 0.625rem;
    left: 1rem;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    pointer-events: none;
    line-height: 1;
  }

  :global(.code-copy-btn) {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    background: rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 3px;
    color: rgba(0, 0, 0, 0.55);
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
    line-height: 1;
  }

  :global([data-theme="dark"] .code-copy-btn) {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.6);
  }

  :global(.code-copy-btn:hover) {
    background: rgba(232, 0, 106, 0.12);
    border-color: rgba(232, 0, 106, 0.5);
    color: #e8006a;
  }

  :global(.code-copy-btn.is-copied) {
    color: #16a34a;
    border-color: rgba(22, 163, 74, 0.4);
  }

  :global([data-theme="dark"] .code-copy-btn.is-copied) {
    color: #4ade80;
    border-color: rgba(74, 222, 128, 0.4);
  }

  :global(.mermaid-diagram) {
    position: relative;
    margin: 2rem -4rem;
    display: flex;
    justify-content: center;
    overflow-x: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 2rem 1.5rem;
  }

  :global(.mermaid-expand-btn) {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    background: rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 3px;
    color: rgba(0, 0, 0, 0.5);
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    line-height: 1;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;

    &:hover {
      background: rgba(232, 0, 106, 0.1);
      border-color: rgba(232, 0, 106, 0.4);
      color: #e8006a;
    }
  }

  :global(.mermaid-lightbox) {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.85);
    align-items: center;
    justify-content: center;
    padding: 2rem;

    &.is-open {
      display: flex;
    }
  }

  :global(.mermaid-lightbox__inner) {
    position: relative;
    background: var(--color-surface);
    padding: 2rem;
    width: 98vw;
    max-width: 98vw;
    height: 94vh;
    max-height: 94vh;
    overflow: auto;
    display: flex;
    align-items: center;
    justify-content: center;

    svg {
      max-width: none;
      height: auto;
    }
  }

  :global(.mermaid-lightbox__close) {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--color-pink);
    border: none;
    color: #ffffff;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    cursor: pointer;
  }

  :global(.mermaid-diagram svg) {
    max-width: 100%;
    height: auto;
  }

  :global(.mermaid-diagram text) {
    fill: var(--color-ink) !important;
  }

  :global(.mermaid-diagram .messageText),
  :global(.mermaid-diagram .labelText),
  :global(.mermaid-diagram .loopText),
  :global(.mermaid-diagram .noteText) {
    fill: var(--color-ink) !important;
    stroke: none !important;
  }

  :global(.mermaid-diagram line),
  :global(.mermaid-diagram path.arrowMarkerPath) {
    stroke: var(--color-ink) !important;
  }

  :global(.mermaid-diagram .messageLine0),
  :global(.mermaid-diagram .messageLine1) {
    stroke: var(--color-ink) !important;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLElement>(".post__content pre")
    .forEach((pre) => {
      const lang = pre.getAttribute("data-language");
      if (lang) {
        const label = document.createElement("span");
        label.className = "code-lang-label";
        label.textContent = lang;
        pre.appendChild(label);
      }

      const btn = document.createElement("button");
      btn.className = "code-copy-btn";
      btn.setAttribute("aria-label", "Copy code");
      btn.textContent = "Copy";

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code")?.innerText ?? pre.innerText;
        await navigator.clipboard.writeText(code);
        btn.textContent = "Copied!";
        btn.classList.add("is-copied");
        setTimeout(() => {
          btn.textContent = "Copy";
          btn.classList.remove("is-copied");
        }, 2000);
      });

      pre.appendChild(btn);
    });

  // Mermaid diagrams — rendered client-side from fenced ```mermaid blocks
  import mermaid, { type MermaidConfig } from "mermaid";

  function getMermaidConfig(isDark: boolean): MermaidConfig {
    return {
      startOnLoad: false,
      theme: isDark ? "dark" : "forest",
      darkMode: isDark,
      look: "handDrawn",
    };
  }

  // Store original definitions so we can re-render on theme change
  const definitions = new Map<HTMLElement, string>();

  document
    .querySelectorAll<HTMLElement>(".post__content pre code.language-mermaid")
    .forEach((codeEl) => {
      const pre = codeEl.parentElement!;
      const definition = codeEl.innerText;
      const container = document.createElement("div");
      container.className = "mermaid-diagram";
      container.textContent = definition;
      pre.replaceWith(container);
      definitions.set(container, definition);
    });

  async function renderDiagrams() {
    const isDark = document.documentElement.dataset.theme === "dark";
    mermaid.initialize(getMermaidConfig(isDark));

    // Reset each container to its original definition before re-rendering
    definitions.forEach((definition, container) => {
      container.removeAttribute("data-processed");
      container.innerHTML = "";
      container.textContent = definition;
    });

    await mermaid.run({
      nodes: document.querySelectorAll(".mermaid-diagram"),
    });
  }

  await renderDiagrams();

  // Lightbox — created once, shared across all diagrams
  const lightbox = document.createElement("div");
  lightbox.className = "mermaid-lightbox";
  lightbox.setAttribute("role", "dialog");
  lightbox.setAttribute("aria-modal", "true");
  lightbox.setAttribute("aria-label", "Diagram fullscreen view");
  const lightboxInner = document.createElement("div");
  lightboxInner.className = "mermaid-lightbox__inner";
  const closeBtn = document.createElement("button");
  closeBtn.className = "mermaid-lightbox__close";
  closeBtn.textContent = "Close";
  closeBtn.setAttribute("aria-label", "Close fullscreen diagram");
  lightboxInner.appendChild(closeBtn);
  lightbox.appendChild(lightboxInner);
  document.body.appendChild(lightbox);

  const closeLightbox = () => {
    lightbox.classList.remove("is-open");
    lightboxInner.querySelector(".mermaid-lightbox__svg")?.remove();
    document.body.style.overflow = "";
  };

  closeBtn.addEventListener("click", closeLightbox);
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });

  function attachExpandButtons() {
    document
      .querySelectorAll<HTMLElement>(".mermaid-diagram")
      .forEach((diagram) => {
        // Avoid duplicating buttons if already present
        if (diagram.querySelector(".mermaid-expand-btn")) return;

        const expandBtn = document.createElement("button");
        expandBtn.className = "mermaid-expand-btn";
        expandBtn.textContent = "Expand";
        expandBtn.setAttribute("aria-label", "View diagram fullscreen");
        diagram.appendChild(expandBtn);

        expandBtn.addEventListener("click", () => {
          const svgClone = diagram
            .querySelector("svg")!
            .cloneNode(true) as SVGElement;
          svgClone.classList.add("mermaid-lightbox__svg");
          // Remove constrained sizing so the SVG fills the lightbox naturally
          svgClone.removeAttribute("style");
          svgClone.removeAttribute("width");
          svgClone.removeAttribute("height");
          svgClone.style.width = "100%";
          svgClone.style.height = "auto";
          svgClone.style.display = "block";
          lightboxInner.appendChild(svgClone);
          lightbox.classList.add("is-open");
          document.body.style.overflow = "hidden";
          closeBtn.focus();
        });
      });
  }

  attachExpandButtons();

  // Re-render diagrams when the theme changes (Header.astro uses setAttribute)
  new MutationObserver(async (mutations) => {
    for (const m of mutations) {
      if (m.attributeName === "data-theme") {
        await renderDiagrams();
        attachExpandButtons();
        break;
      }
    }
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // Highlight the active ToC link as the user scrolls
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc__link");
  if (tocLinks.length) {
    const setActive = (id: string) => {
      tocLinks.forEach((l) =>
        l.classList.toggle("is-active", l.getAttribute("href") === `#${id}`)
      );
    };

    const headingEls = document.querySelectorAll<HTMLElement>(
      ".post__content h2, .post__content h3"
    );
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: "0px 0px -80% 0px" }
    );
    headingEls.forEach((h) => obs.observe(h));
  }
</script>
