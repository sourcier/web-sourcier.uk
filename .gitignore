# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# pagefind dev index (generated by pnpm search:index, not committed)
public/pagefind/
public/search-thumbnails/
