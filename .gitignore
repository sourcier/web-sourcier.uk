# blog content (cloned from private repo at build time)
collections/posts/

# environment variables
.env
.env.production
!.env.example

# Playwright MCP test artefacts
.playwright-mcp/

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Local Netlify folder
.netlify

# Deno lock file (generated by VS Code Deno extension when resolving edge function imports)
deno.lock
